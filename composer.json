{
    "name": "hughcube/spreadsheet",
    "description": "A PHP library for parsing Excel spreadsheets with automatic header detection and data validation",
    "license": "MIT",
    "authors": [
        {
            "name": "hugh.li",
            "email": "hugh.li@foxmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "phpoffice/phpspreadsheet": "^1.23 || ^2.0 || ^3.0 || ^4.0 || ^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "*",
        "squizlabs/php_codesniffer": "*",
        "phpstan/phpstan": "*",
        "openspout/openspout": "^5.3"
    },
    "autoload": {
        "psr-4": {
            "HughCube\\Spreadsheet\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HughCube\\Spreadsheet\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse -vvv",
        "check-style": "phpcs -p --standard=PSR2 src/ -v",
        "fix-style": "phpcbf -p --standard=PSR2 src/ -v"
    },
    "suggest": {
        "openspout/openspout": "Required for OpenSpout driver (streaming, low memory)",
        "ext-xlswriter": "Required for Xlswriter driver (C extension, fastest)"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
